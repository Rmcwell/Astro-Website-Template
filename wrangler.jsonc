{
  "name": "astro-website-template",
  "compatibility_date": "2026-03-24",
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    {
      "pattern": "clientdomain.com",
      "custom_domain": true
    },
    {
      "pattern": "www.clientdomain.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
