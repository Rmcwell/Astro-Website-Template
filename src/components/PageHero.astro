---
import { Image } from "astro:assets";
//import beachImage from "../assets/beach.webp"

interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
  compact?: boolean;
}

const {
  title,
  subtitle,
  tagline,
} = Astro.props;
---

<section
  class="relative overflow-hidden w-full flex flex-col justify-center min-h-[60vh] pt-24 pb-12 md:pt-32 md:pb-20"
>
  <!-- Background image -->
  <!-- <Image
    src={beachImage}
    alt="Error Image"
    width={1920}
    height={1080}
    class="absolute inset-0 w-full h-full object-cover"
  /> -->

  <Image
    src="https://images.unsplash.com/photo-1533852990198-bdd4082bf8c0?q=80&w=1933&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
    alt="Error Image"
    width={1920}
    height={1080}
    class="absolute inset-0 w-full h-full object-cover"
  />

  <div class="absolute inset-0 bg-linear-to-r from-black/80 via-black/60 to-black/20"></div>

  <div class="relative z-10 w-full">
    <div class="container mx-auto px-6">
      <div id="page-hero-content" class="max-w-2xl opacity-0 translate-y-8">
        {tagline && (
          <p class="text-xs md:text-sm tracking-[0.35em] uppercase text-white/70 mb-4">
            {tagline}
          </p>
        )}
        <h1 class="text-4xl md:text-7xl leading-tight text-white mb-6">
          {title}
        </h1>
        <div class="w-16 h-px bg-brand-accent mb-6"></div>
        {subtitle && (
          <p class="text-base md:text-lg text-white/80 max-w-lg leading-relaxed">
            {subtitle}
          </p>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  #page-hero-content {
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
  #page-hero-content.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const content = document.getElementById("page-hero-content");
  if (content) {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        content.classList.add("visible");
      });
    });
  }
</script>